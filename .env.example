# NGA-WATCH Environment Variables
# Copy this file to .env and fill in your values

# API endpoint override (leave blank to use auto-detection)
VITE_API_URL=

# Google Maps API key (for interactive map on /map page)
VITE_GOOGLE_MAPS_KEY=

# Optional: cache TTL in seconds (default: 3600 = 1 hour)
VITE_CACHE_TTL=3600
